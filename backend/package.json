{
  "name": "gym-backend",
  "private": true,
  "scripts": {
    "dev": "ts-node src/server.ts",
    "dev:watch": "node --watch-path=./src --watch -r ts-node/register src/server.ts",
    "start:docker": "prisma migrate deploy && npm run dev:watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "prisma": "^6.19.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  }
}
