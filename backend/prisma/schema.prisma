generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ProviderKind {
  CASH
  TOTALPASS
  WELLHUB
}

enum PlanType {
  DAILY
  MONTHLY
  ANNUAL
}

enum QualityLevel {
  BASIC
  ADVANCED
  PRO
}

model Person {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  birthDate DateTime
  gender    Gender
  cpf       String   @unique
  role      Role     @default(STUDENT)
  planId    Int?
  plan      Plan?    @relation(fields: [planId], references: [id])
}

model Plan {
  id           Int          @id @default(autoincrement())
  name         String
  type         PlanType
  qualityLevel QualityLevel
  priceCents   Int
  providerKind ProviderKind @default(CASH)
  enabled      Boolean      @default(true)
  persons      Person[]
}
