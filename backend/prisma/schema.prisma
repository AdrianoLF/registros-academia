generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Person {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  birthDate DateTime
  gender    Gender
  cpf       String   @unique
  role      Role     @default(STUDENT)
}
